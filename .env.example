# ============================================================
# SkillMatch 环境变量配置模板
# 使用方法: cp .env.example .env 然后填写实际值
# ============================================================

# ==================== MySQL ====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_password

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_DB=0           # 仅 AI Engine 使用，默认 0

# ==================== 高德地图 API ====================
# 申请地址: https://console.amap.com/
GAODE_API_KEY=your_gaode_key

# ==================== AI 引擎地址 ====================
# 本地开发默认 http://localhost:8000，Docker 部署用 http://ai-engine:8000
AI_ENGINE_URL=http://localhost:8000

# ==================== 阿里云 OSS (文件上传) ====================
# 以下变量通过 OssUtil.java 读取
# OSS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID_HERE
# OSS_ACCESS_KEY_SECRET=YOUR_ACCESS_KEY_SECRET_HERE

# ==================== AI 嵌入模型 ====================
# 可选: BAAI/bge-m3 (推荐) | BAAI/bge-small-zh (轻量) | all-MiniLM-L6-v2 (旧)
# AI_EMBEDDING_MODEL=BAAI/bge-m3

# Hugging Face 镜像（国内服务器使用）
# HF_ENDPOINT=https://hf-mirror.com

# ==================== LLM 匹配解释 ====================
# 必填：OpenAI 兼容的 API Key（推荐 DeepSeek，便宜好用）
# LLM_API_KEY=your_llm_api_key

# 可选：LLM 提供商配置
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# 可选：其他 LLM 提供商
# 通义千问:  LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  LLM_MODEL=qwen-plus
# OpenAI:    LLM_BASE_URL=https://api.openai.com/v1                     LLM_MODEL=gpt-4o-mini

# ==================== AI 引擎高级调参（通常不改）====================
# AI_MAX_CANDIDATES=200          # 单次匹配最大候选人数
# AI_SEMANTIC_WEIGHT=0.3         # 语义相似度权重
# AI_COMPLEMENT_WEIGHT=0.4       # 技能互补度权重
# AI_INTEREST_WEIGHT=0.3         # 兴趣重叠度权重
# AI_HOST=0.0.0.0                # FastAPI 监听地址（Docker 用）
# AI_PORT=8000                   # FastAPI 端口

# ==================== Java 应用 ====================
# Docker 部署时 JVM 参数
# JAVA_OPTS=-Xms256m -Xmx512m
